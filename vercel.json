{
  "buildCommand": "EXPO_PUBLIC_SOUNDLOG_API_SOURCE=server EXPO_PUBLIC_SOUNDLOG_API_BASE_URL=/api/soundlog npx expo export --platform web",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/soundlog/:path*",
      "destination": "https://api.soundlog.shop/:path*"
    }
  ]
}
