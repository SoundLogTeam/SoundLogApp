{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_ENABLE_DEV_AUTH_FALLBACK": "true",
        "EXPO_PUBLIC_SOUNDLOG_API_BASE_URL": "http://54.226.62.131:4000",
        "EXPO_PUBLIC_SOUNDLOG_API_SOURCE": "server"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_ENABLE_DEV_AUTH_FALLBACK": "true",
        "EXPO_PUBLIC_SOUNDLOG_API_BASE_URL": "http://54.226.62.131:4000",
        "EXPO_PUBLIC_SOUNDLOG_API_SOURCE": "server"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_ENABLE_DEV_AUTH_FALLBACK": "false",
        "EXPO_PUBLIC_ENABLE_SOCIAL_LOGIN": "true",
        "EXPO_PUBLIC_SOUNDLOG_SUPPORT_EMAIL": "support@soundlog.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
